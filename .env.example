# =====================================================
# Environment Variables for Docker Compose
# Copy this file to .env and fill in real values
#   cp .env.example .env
# =====================================================

# MySQL root password
DB_ROOT_PASSWORD=<strong-password>

# Database name (default: club_management)
DB_NAME=club_management

# Backend - Database connection (Docker internal hostname is "mysql")
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=<same-as-DB_ROOT_PASSWORD>

# Backend - JWT (generate a random string at least 32 chars)
JWT_SECRET=<generate-a-long-random-string-at-least-32-chars>

# Backend - LLM / AI (DeepSeek API)
LLM_API_KEY=<your-deepseek-api-key>
LLM_PROVIDER=deepseek
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_MODEL=deepseek-chat

# Backend - CORS (set to your ECS public IP, e.g. http://47.96.123.45)
APP_CORS_ALLOWED_ORIGINS=http://YOUR_ECS_PUBLIC_IP

# Backend - Langfuse observability (optional, leave false to disable)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
